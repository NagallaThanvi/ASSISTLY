# ========================================
# ASSISTLY - Environment Variables
# ========================================
# SECURITY NOTE: Never commit your actual .env file to Git!
# Copy this file to .env and fill in your actual values

# ========================================
# FIREBASE CONFIGURATION (REQUIRED)
# ========================================
# Get these from: https://console.firebase.google.com
# Project Settings > General > Your apps > SDK setup and configuration

REACT_APP_FIREBASE_API_KEY=your-api-key-here
REACT_APP_FIREBASE_AUTH_DOMAIN=your-project-id.firebaseapp.com
REACT_APP_FIREBASE_PROJECT_ID=your-project-id
REACT_APP_FIREBASE_STORAGE_BUCKET=your-project-id.firebasestorage.app
REACT_APP_FIREBASE_MESSAGING_SENDER_ID=your-messaging-sender-id
REACT_APP_FIREBASE_APP_ID=your-app-id

# Firebase Cloud Messaging VAPID Key (OPTIONAL - for push notifications)
# Get from: Firebase Console > Project Settings > Cloud Messaging > Web Push certificates
REACT_APP_FIREBASE_VAPID_KEY=your-vapid-key-here

# Firebase Analytics Measurement ID (OPTIONAL)
REACT_APP_FIREBASE_MEASUREMENT_ID=G-XXXXXXXXXX

# Google Analytics Measurement ID (OPTIONAL - legacy)
REACT_APP_GA_ID=G-XXXXXXXXXX

# ========================================
# APPLICATION CONFIGURATION
# ========================================
REACT_APP_NAME="Assistly"
REACT_APP_DESCRIPTION="Your trusted community assistance platform - connecting neighbors who care"
REACT_APP_URL=http://localhost:3000

# ========================================
# FEATURE TOGGLES
# ========================================
REACT_APP_ENABLE_ANALYTICS=false
REACT_APP_ENABLE_NOTIFICATIONS=true
REACT_APP_ENABLE_VOICE_FEATURES=true

# ========================================
# API & PERFORMANCE SETTINGS
# ========================================
REACT_APP_API_TIMEOUT=30000
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_MAX_REQUESTS_PER_MINUTE=60

# ========================================
# AI CHATBOT CONFIGURATION (CHOOSE ONE)
# ========================================
# Option 1: Groq (RECOMMENDED - FREE, ultra-fast, 14.4K requests/day)
# Get API key from: https://console.groq.com
REACT_APP_GROQ_API_KEY=

# Option 2: Hugging Face (Alternative - FREE forever, slower)
# Get API key from: https://huggingface.co/settings/tokens
# REACT_APP_HUGGINGFACE_API_KEY=hf_your_token_here

# Option 3: OpenAI (Paid after $5 trial credit)
# Get API key from: https://platform.openai.com/api-keys
# REACT_APP_OPENAI_API_KEY=sk-your_key_here

# ========================================
# EMAIL CONFIGURATION (OPTIONAL)
# ========================================
# SendGrid for transactional emails (notifications, password reset, etc.)
# Get API key from: https://app.sendgrid.com/settings/api_keys
# IMPORTANT: Rotate this key regularly and use environment-specific keys
REACT_APP_SENDGRID_API_KEY=

# ========================================
# DEVELOPMENT & DEBUGGING
# ========================================
# Set to 'true' to enable verbose logging (development only)
REACT_APP_DEBUG_MODE=false

# Set to 'true' to enable React strict mode
REACT_APP_STRICT_MODE=true

# ========================================
# SECURITY NOTES
# ========================================
# 1. NEVER commit your actual .env file to version control
# 2. Use different API keys for development, staging, and production
# 3. Rotate API keys regularly (at least every 90 days)
# 4. Use Firebase Security Rules to protect your data
# 5. Enable Firebase App Check for production
# 6. Monitor API usage and set up billing alerts
# 7. For production, use environment-specific secrets management
#    (GitHub Secrets, AWS Secrets Manager, etc.)

# ========================================
# VOICE FEATURES
# ========================================
# Voice input and output use the browser's Web Speech API
# No API key needed - works in Chrome, Edge, and Safari
# Will gracefully degrade in unsupported browsers