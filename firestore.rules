rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isAuthenticated() {
      return request.auth != null;
    }

    function isOwner(userId) {
      return request.auth.uid == userId;
    }

    function getUserData() {
      return exists(/databases/$(database)/documents/users/$(request.auth.uid))
        ? get(/databases/$(database)/documents/users/$(request.auth.uid)).data
        : null;
    }

    function isMemberOfCommunity(communityId) {
      let userData = getUserData();
      return userData != null && (
        userData.communityId == communityId || 
        (userData.communities != null && communityId in userData.communities)
      );
    }

    function isAdminOfCommunity(communityId) {
      let userData = getUserData();
      return userData != null &&
             userData.role in ['super_admin', 'community_admin'] &&
             isMemberOfCommunity(communityId);
    }

    function isSuperAdminOrCommunityAdmin() {
      let userData = getUserData();
      return userData != null && userData.role in ['super_admin', 'community_admin'];
    }

    // Communities collection - public read to browse, admin create
    match /communities/{communityId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && isSuperAdminOrCommunityAdmin();
      allow update, delete: if isAuthenticated() && 
                               (resource.data.adminId == request.auth.uid || 
                                (getUserData() != null && getUserData().role == 'super_admin'));
    }

    // Join Requests collection
    match /join_requests/{requestId} {
      allow create: if isAuthenticated() && 
                     exists(/databases/$(database)/documents/communities/$(request.resource.data.communityId)) &&
                     request.resource.data.userId == request.auth.uid;
      allow read: if isAuthenticated() && 
                   (request.auth.uid == resource.data.userId || 
                    isSuperAdminOrCommunityAdmin());
      allow update, delete: if isAuthenticated() && isSuperAdminOrCommunityAdmin();
    }

    // Requests collection - CRITICAL: Only visible within same community
    match /requests/{requestId} {
      // Read: Community members, request owner, or volunteer who claimed it
      allow read: if isAuthenticated() && 
                    (isMemberOfCommunity(resource.data.communityId) || 
                     resource.data.createdByUid == request.auth.uid ||
                     resource.data.claimedByUid == request.auth.uid);
      
      // List/Query: Allow users to query their own requests or community requests
      allow list: if isAuthenticated() && 
                    (isMemberOfCommunity(request.query.communityId) ||
                     request.query.createdByUid == request.auth.uid ||
                     request.query.claimedByUid == request.auth.uid);
      
      // Create: Must be authenticated and owner
      allow create: if isAuthenticated() && 
                     request.resource.data.createdByUid == request.auth.uid;
      
      // Update: Owner or admin can always update. Members can update only if they are the assigned claimer (no direct claiming).
      allow update: if isAuthenticated() && 
                     (resource.data.createdByUid == request.auth.uid ||
                      isAdminOfCommunity(resource.data.communityId) ||
                      // Allow the assigned volunteer to update (e.g., mark complete), but not to claim directly
                      (isMemberOfCommunity(resource.data.communityId) &&
                       resource.data.claimedByUid == request.auth.uid));
      
      // Delete: Only owner or admin can delete
      allow delete: if isAuthenticated() && 
                     (resource.data.createdByUid == request.auth.uid ||
                      isAdminOfCommunity(resource.data.communityId));
    }

    // Request Offers subcollection for owner-approval model
    match /requests/{requestId}/offers/{offerId} {
      function requestCommunityId() {
        return get(/databases/$(database)/documents/requests/$(requestId)).data.communityId;
      }
      function requestOwnerUid() {
        return get(/databases/$(database)/documents/requests/$(requestId)).data.createdByUid;
      }

      // Read offers: owner, admin, or the author of the offer
      allow read: if isAuthenticated() && (
                    requestOwnerUid() == request.auth.uid ||
                    isAdminOfCommunity(requestCommunityId()) ||
                    resource.data.userId == request.auth.uid
                  );

      // Create an offer: community member offering themselves
      allow create: if isAuthenticated() &&
                     isMemberOfCommunity(requestCommunityId()) &&
                     request.resource.data.userId == request.auth.uid;

      // Update/Delete: author of offer, request owner, or community admin can update
      allow update, delete: if isAuthenticated() &&
                             (resource.data.userId == request.auth.uid ||
                              requestOwnerUid() == request.auth.uid ||
                              isAdminOfCommunity(requestCommunityId()));
    }

    // User profiles - users can read own, admins can read community members
    match /users/{userId} {
      allow read: if isAuthenticated() && 
                    (isOwner(userId) || 
                     isSuperAdminOrCommunityAdmin());
      allow create: if isAuthenticated() && isOwner(userId);
      allow update: if isAuthenticated() && 
                      (isOwner(userId) || 
                       isSuperAdminOrCommunityAdmin());
      allow delete: if isAuthenticated() && getUserData() != null && getUserData().role == 'super_admin';
    }

    // Messages collection - users can read/write their own messages
    match /messages/{messageId} {
      allow read: if isAuthenticated();
      allow create: if isAuthenticated() && 
                     request.resource.data.senderId == request.auth.uid;
      allow update, delete: if isAuthenticated() && resource.data.senderId == request.auth.uid;
    }

    // Gamification profiles
    match /gamification/{userId} {
      allow read: if isAuthenticated() && isOwner(userId);
      allow write: if isAuthenticated() && isOwner(userId);
    }

    // Notifications
    match /notifications/{notificationId} {
      function notifRequestId() {
        return request.resource.data.requestId;
      }
      function notifRequestCommunityId() {
        return notifRequestId() != null ? get(/databases/$(database)/documents/requests/$(notifRequestId())).data.communityId : null;
      }
      function notifRequestOwnerUid() {
        return notifRequestId() != null ? get(/databases/$(database)/documents/requests/$(notifRequestId())).data.createdByUid : null;
      }
      function notifRequestClaimerUid() {
        return notifRequestId() != null ? get(/databases/$(database)/documents/requests/$(notifRequestId())).data.claimedByUid : null;
      }

      // Recipients can read their notifications
      allow read: if isAuthenticated() && resource.data.userId == request.auth.uid;

      // Create: allow recipient to create for themselves OR
      // allow request owner/assigned volunteer/admin to create notifications for others related to that request
      allow create: if isAuthenticated() && (
        request.resource.data.userId == request.auth.uid ||
        (
          notifRequestId() != null && (
            notifRequestOwnerUid() == request.auth.uid ||
            notifRequestClaimerUid() == request.auth.uid ||
            isAdminOfCommunity(notifRequestCommunityId())
          )
        )
      );

      // Update/Delete: only the recipient can modify their notification (e.g., mark as read)
      allow update, delete: if isAuthenticated() && resource.data.userId == request.auth.uid;
    }

    // Activity Logs (Admin only)
    match /activity_logs/{logId} {
      allow read: if isAuthenticated() && 
                    isSuperAdminOrCommunityAdmin() &&
                    isMemberOfCommunity(resource.data.communityId);
      allow write: if isAuthenticated();
    }

    // Admin Logs (Admin actions tracking)
    match /admin_logs/{logId} {
      allow read: if isAuthenticated() && isSuperAdminOrCommunityAdmin();
      allow write: if isAuthenticated() && isSuperAdminOrCommunityAdmin();
    }

    // Audit Logs (Super Admin only)
    match /audit_logs/{logId} {
      allow read: if isAuthenticated() && getUserData() != null && getUserData().role == 'super_admin';
      allow write: if false; // System-only writes
    }
  }
}